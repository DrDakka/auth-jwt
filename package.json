{
  "name": "auth-jwt",
  "version": "1.0.0",
  "type": "module",
  "description": "JWT authentication REST API built with Node.js, TypeScript, and PostgreSQL",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "npm run format && eslint ./src",
    "format": "prettier --ignore-path .prettierignore --write './src/**/*.{js,ts}'"
  },
  "author": "Bespalov Tymofii",
  "license": "MIT",
  "devDependencies": {
    "@types/nodemailer": "^7.0.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.3.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.0",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "resend": "^6.9.3",
    "sequelize": "^6.37.7",
    "zod": "^4.3.6"
  }
}
